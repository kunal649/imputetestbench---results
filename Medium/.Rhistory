plotModel <- function(graph) {
# Step 1: Extract unique states and rules
states <- unique(c(graph$state1, graph$state2))
rules <- unique(graph$rule)
print(paste("States:", paste(states, collapse=", ")))
print(paste("Rules:", paste(rules, collapse=", ")))
}
# Test it
plotModel(mock_graph)
print(mock_graph)
plotModel <- function(graph){
states <- unique(c(graph$state1, graph$state2))
rules <- unique(graph$rule)
edge_matrix <- matrix("", nrow = length(states), ncol = length(rules))
rownames(edge_matrix) <- states
colnames(edge_matrix) <- paste("Rule", rules)
for (i in 1:nrow(graph)) {
state <- graph$state1[i]  # Starting state
rule <- graph$rule[i]
edge_type <- graph$type[i]
target <- graph$state2[i]
# Find position in matrix
row_idx <- which(states == state)
col_idx <- which(rules == rule)
# Add edge info (format: "type→target")
edge_info <- paste0(edge_type, "→", target)
# Append to cell (there might be multiple edges)
if (edge_matrix[row_idx, col_idx] == "") {
edge_matrix[row_idx, col_idx] <- edge_info
} else {
edge_matrix[row_idx, col_idx] <- paste(edge_matrix[row_idx, col_idx], edge_info, sep="\n")
}
}
print(edge_matrix)
}
plotModel(mock_graph)
plotModel <- function(graph) {
# Step 1: Extract unique states and rules
states <- unique(c(graph$state1, graph$state2))
rules <- unique(graph$rule)
# Step 2: Create empty matrix
edge_matrix <- matrix("", nrow = length(states), ncol = length(rules))
rownames(edge_matrix) <- states
colnames(edge_matrix) <- paste("Rule", rules)
# Step 3: Fill matrix with edges
for (i in 1:nrow(graph)) {
state <- graph$state1[i]
rule <- graph$rule[i]
edge_type <- graph$type[i]
target <- graph$state2[i]
row_idx <- which(states == state)
col_idx <- which(rules == rule)
edge_info <- paste0(edge_type, "→", target)
if (edge_matrix[row_idx, col_idx] == "") {
edge_matrix[row_idx, col_idx] <- edge_info
} else {
edge_matrix[row_idx, col_idx] <- paste(edge_matrix[row_idx, col_idx], edge_info, sep="\n")
}
}
# Step 4: DRAW the matrix
n_states <- length(states)
n_rules <- length(rules)
# Create blank plot
plot(1, type="n", xlim=c(0, n_rules + 1), ylim=c(0, n_states + 1),
xlab="", ylab="", xaxt="n", yaxt="n", main="Graph Structure Matrix")
# Draw grid lines
for (i in 0:(n_rules + 1)) {
abline(v = i, col = "gray", lty = 2)
}
for (i in 0:(n_states + 1)) {
abline(h = i, col = "gray", lty = 2)
}
# Add column headers (rules)
for (j in 1:n_rules) {
text(x = j + 0.5, y = n_states + 0.5, labels = paste("Rule", rules[j]), font = 2)
}
# Add row headers (states)
for (i in 1:n_states) {
text(x = 0.5, y = n_states - i + 0.5, labels = states[i], font = 2)
}
# Add edge information in cells
for (i in 1:n_states) {
for (j in 1:n_rules) {
text(x = j + 0.5, y = n_states - i + 0.5,
labels = edge_matrix[i, j], cex = 0.7)
}
}
}
plotModel(mock_graph)
# Add edge information in cells
for (i in 1:n_states) {
for (j in 1:n_rules) {
text(x = j + 0.5, y = n_states - i + 0.5,
labels = edge_matrix[i, j], cex = 0.7)
}
}
