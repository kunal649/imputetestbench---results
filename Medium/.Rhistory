# Day 133 - GSoC Easy Task: Exploring imputeTestbench
# Author: [Your Name]
# Install and load package
library(imputeTestbench)
# The package uses built-in R datasets for testing
# Let's use 'nottem' - Nottingham temperature data (1920-1939)
data("nottem")
# First, let me see what this data looks like
print(head(nottem, 20))
plot(nottem, main="Nottingham Monthly Temperatures (1920-1939)",
ylab="Temperature (F)")
# This is a monthly temperature time series with 240 observations
# Now let's test the main function: impute_errors()
# Run the benchmark with default settings
results <- impute_errors(data = nottem)
# See what we got
print(results)
# The output shows RMSE values for different imputation methods
# at different percentages of missing data (10%, 20%, ... 90%)
# Let's visualize this
plot_errors(results, plotType = 'line')
# I can also see the imputed values visually
plot_impute(dataIn = nottem, missPercent = 30)
