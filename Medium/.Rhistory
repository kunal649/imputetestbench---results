plotModel <- function(my_graph) {
all_states <- unique(c(my_graph$state1, my_graph$state2))
all_types <- unique(my_graph$type)
state_order <- data.frame(state = all_states, y = 1:length(all_states))
type_order <- data.frame(type = all_types, x = 1:length(all_types))
df_plot <- merge(my_graph, state_order, by.x = "state1", by.y = "state")
df_plot <- merge(df_plot, type_order, by.x = "type", by.y = "type")
df_plot$y_end <- state_order$y[match(df_plot$state2, state_order$state)]
ggplot(df_plot) +
geom_point(aes(x = x, y = y), size = 5, color = "blue") +
geom_segment(aes(x = x, y = y, xend = x, yend = y_end),
arrow = arrow(length = unit(0.3, "cm")),
color = "red", size = 1, alpha = 0.8) +
scale_y_continuous(breaks = state_order$y, labels = state_order$state, name = "States (Rows)") +
scale_x_continuous(breaks = type_order$x, labels = type_order$type, name = "Rules (Columns)") +
geom_text(aes(x = x, y = (y + y_end)/2, label = paste0("p=", penalty)),
nudge_x = 0.1, size = 3, color = "black") +
theme_minimal() +
labs(title = "gfpop Graph Model: Matrix Layout",
subtitle = "Rows = States, Columns = Transition Rules")
}
str(my_graph)
